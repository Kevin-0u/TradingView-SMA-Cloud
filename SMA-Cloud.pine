//@version=6
indicator(title='SMA Cloud with HUD', shorttitle='SMAs + HUD', overlay=true)

// SMA Cloud, Multi-SMA and ATR Indicator
//
// Version: 1.0
// Author: KUnit
// License: MPL 2.0


// Defaults
var MA1 = 5
var MA2 = 10
var MA3 = 20
var MA4 = 50
var MA5 = 60
var MA6 = 100
var MA7 = 120
var MA8 = 200
var ATR = 14

var COLOR1 = #FFD700 // SMA(5) Fast
var COLOR2 = #007BFF // SMA(10) Slow
var COLOR3 = #FF1493 // SMA(20)
var COLOR4 = #A5FF00 // SMA(50)
var COLOR5 = #8A2BE2 // SMA(60)
var COLOR6 = #00FFFF // SMA(100)
var COLOR7 = #FF00FF // SMA(120)
var COLOR8 = #FF8C00 // SMA(200)
var COLOR_ATR = #B3D4FF // ATR

var COLOR_BULL = #2ECC71 // When SMA fast > SMA slow
var COLOR_BEAR = #E74C3C // When SMA fast < SMA slow

var TABLE_LEFT_OFFSET = 21
var TABLE_TRANSPARENCY = 10
var TREND_TRANSPARENCY = 80


// Customization unlikely needed beyond this line
//-----------------------------------------

// Inputs
ma1Show = input.bool(title='Chart', defval=true, inline='1', tooltip='Show MA1 on chart')
ma1ShowTable = input.bool(title='HUD', defval=true, inline='1', tooltip='Show MA1 in heads-up display')
ma1Length = input.int(title='MA1 (Fast)', defval=MA1, minval=1, maxval=500, inline='1', tooltip='Fast moving average period for cloud visualization')
ma1Color = input.color(title='', defval=COLOR1, inline='1')

ma2Show = input.bool(title='Chart', defval=true, inline='2', tooltip='Show MA2 on chart')
ma2ShowTable = input.bool(title='HUD', defval=true, inline='2', tooltip='Show MA2 in heads-up display')
ma2Length = input.int(title='MA2 (Slow)', defval=MA2, minval=1, maxval=500, inline='2', tooltip='Slow moving average period for cloud visualization')
ma2Color = input.color(title='', defval=COLOR2, inline='2')

ma3Show = input.bool(title='Chart', defval=true, inline='3', tooltip='Show MA3 on chart')
ma3ShowTable = input.bool(title='HUD', defval=true, inline='3', tooltip='Show MA3 in heads-up display')
ma3Length = input.int(title='MA3', defval=MA3, minval=1, maxval=500, inline='3', tooltip='Third moving average period (commonly 20)')
ma3Color = input.color(title='', defval=COLOR3, inline='3')

ma4Show = input.bool(title='Chart', defval=true, inline='4', tooltip='Show MA4 on chart')
ma4ShowTable = input.bool(title='HUD', defval=true, inline='4', tooltip='Show MA4 in heads-up display')
ma4Length = input.int(title='MA4', defval=MA4, minval=1, maxval=500, inline='4', tooltip='Fourth moving average period (commonly 50)')
ma4Color = input.color(title='', defval=COLOR4, inline='4')

ma5Show = input.bool(title='Chart', defval=true, inline='5', tooltip='Show MA5 on chart')
ma5ShowTable = input.bool(title='HUD', defval=true, inline='5', tooltip='Show MA5 in heads-up display')
ma5Length = input.int(title='MA5', defval=MA5, minval=1, maxval=500, inline='5', tooltip='Fifth moving average period (commonly 60)')
ma5Color = input.color(title='', defval=COLOR5, inline='5')

ma6Show = input.bool(title='Chart', defval=true, inline='6', tooltip='Show MA6 on chart')
ma6ShowTable = input.bool(title='HUD', defval=true, inline='6', tooltip='Show MA6 in heads-up display')
ma6Length = input.int(title='MA6', defval=MA6, minval=1, maxval=500, inline='6', tooltip='Sixth moving average period (commonly 100)')
ma6Color = input.color(title='', defval=COLOR6, inline='6')

ma7Show = input.bool(title='Chart', defval=true, inline='7', tooltip='Show MA7 on chart')
ma7ShowTable = input.bool(title='HUD', defval=true, inline='7', tooltip='Show MA7 in heads-up display')
ma7Length = input.int(title='MA7', defval=MA7, minval=1, maxval=500, inline='7', tooltip='Seventh moving average period (commonly 120)')
ma7Color = input.color(title='', defval=COLOR7, inline='7')

ma8Show = input.bool(title='Chart', defval=true, inline='8', tooltip='Show MA8 on chart')
ma8ShowTable = input.bool(title='HUD', defval=true, inline='8', tooltip='Show MA8 in heads-up display')
ma8Length = input.int(title='MA8', defval=MA8, minval=1, maxval=500, inline='8', tooltip='Eighth moving average period (commonly 200)')
ma8Color = input.color(title='', defval=COLOR8, inline='8')

// Cloud Settings
bullColor = input.color(title='Bullish Cloud', defval=COLOR_BULL, group='Cloud', tooltip='Cloud color when fast MA (MA1) is above slow MA (MA2)')
bearColor = input.color(title='Bearish Cloud', defval=COLOR_BEAR, group='Cloud', tooltip='Cloud color when fast MA (MA1) is below slow MA (MA2)')
trendTransparency = input.int(title='Cloud Transparency', defval=TREND_TRANSPARENCY, minval=0, maxval=100, group='Cloud', tooltip='Transparency level of the cloud fill between fast and slow MAs (0=opaque, 100=invisible)')

// ATR Settings
atrShowTable = input.bool(true, "Show in HUD", group='ATR', inline='9', tooltip='Show ATR in heads-up display')
atrPeriod = input.int(title='Period', defval=ATR, minval=1, maxval=100, group='ATR', inline='9', tooltip='ATR calculation period\n• 5-10: Scalpers/Day Traders (more sensitive to short-term volatility)\n• 14: Swing Traders (balanced view, industry standard)\n• 20+: Mid/Long-term Traders (smoother, filters out noise)')
atrColor = input.color(COLOR_ATR, "", group='ATR', inline='9')

// Miscellaneous Settings
tableTopOffset = input.string(title='HUD Text Size', defval='Tiny', options=['Tiny', 'Small', 'Normal', 'Large', 'Huge'], group='Misc', display=display.none, tooltip='Adjust the size of the HUD text')
tableLeftOffset = input.int(title='HUD Left Offset', defval=TABLE_LEFT_OFFSET, minval=0, maxval=50, group='Misc', display=display.none, tooltip='Horizontal positioning of the HUD')
tableTransparency = input.int(title='HUD Transparency', defval=TABLE_TRANSPARENCY, minval=0, maxval=100, group='Misc', display=display.none, tooltip='Transparency level of HUD cell backgrounds (0=opaque, 100=invisible)')

// Calculate SMAs (daily timeframe) - for HUD display
// Using lookahead=barmerge.lookahead_off to prevent repainting
ma1_daily = request.security(syminfo.tickerid, 'D', ta.sma(close, ma1Length), lookahead=barmerge.lookahead_off)
ma2_daily = request.security(syminfo.tickerid, 'D', ta.sma(close, ma2Length), lookahead=barmerge.lookahead_off)
ma3_daily = request.security(syminfo.tickerid, 'D', ta.sma(close, ma3Length), lookahead=barmerge.lookahead_off)
ma4_daily = request.security(syminfo.tickerid, 'D', ta.sma(close, ma4Length), lookahead=barmerge.lookahead_off)
ma5_daily = request.security(syminfo.tickerid, 'D', ta.sma(close, ma5Length), lookahead=barmerge.lookahead_off)
ma6_daily = request.security(syminfo.tickerid, 'D', ta.sma(close, ma6Length), lookahead=barmerge.lookahead_off)
ma7_daily = request.security(syminfo.tickerid, 'D', ta.sma(close, ma7Length), lookahead=barmerge.lookahead_off)
ma8_daily = request.security(syminfo.tickerid, 'D', ta.sma(close, ma8Length), lookahead=barmerge.lookahead_off)

// Calculate ATR
atr = ta.atr(atrPeriod)

// Create HUD (heads-up display) positioned to top-left corner
var table maTable = table.new(position.top_left, 10, 3, border_width=0)
// Convert input string to size enum
var text_size = tableTopOffset == 'Tiny' ? size.tiny
  : tableTopOffset == 'Small' ? size.small
  : tableTopOffset == 'Large' ? size.large
  : tableTopOffset == 'Huge' ? size.huge
  : size.normal

// Only update the HUD on the last bar to save resources
if barstate.islast
    table.cell(maTable, 0, 0, '', width=tableLeftOffset, text_size=text_size) // Set cell position

    column = 1
    
    // MA1
    if ma1ShowTable
        table.cell(maTable, column, 1,
          'SMA(' + str.tostring(ma1Length) + ')',
          bgcolor=color.new(ma1Color, tableTransparency))
        table.cell(maTable, column, 2,
          str.tostring(ma1_daily, format.mintick),
          bgcolor=color.new(ma1Color, tableTransparency))
        column += 1
    
    // MA2
    if ma2ShowTable
        table.cell(maTable, column, 1,
          'SMA(' + str.tostring(ma2Length) + ')',
          bgcolor=color.new(ma2Color, tableTransparency))
        table.cell(maTable, column, 2,
          str.tostring(ma2_daily, format.mintick),
          bgcolor=color.new(ma2Color, tableTransparency))
        column += 1
    
    // MA3
    if ma3ShowTable
        table.cell(maTable, column, 1,
          'SMA(' + str.tostring(ma3Length) + ')',
          bgcolor=color.new(ma3Color, tableTransparency))
        table.cell(maTable, column, 2,
          str.tostring(ma3_daily, format.mintick),
          bgcolor=color.new(ma3Color, tableTransparency))
        column += 1
    
    // MA4
    if ma4ShowTable
        table.cell(maTable, column, 1,
          'SMA(' + str.tostring(ma4Length) + ')',
          bgcolor=color.new(ma4Color, tableTransparency))
        table.cell(maTable, column, 2,
          str.tostring(ma4_daily, format.mintick),
          bgcolor=color.new(ma4Color, tableTransparency))
        column += 1
    
    // MA5
    if ma5ShowTable
        table.cell(maTable, column, 1,
          'SMA(' + str.tostring(ma5Length) + ')',
          bgcolor=color.new(ma5Color, tableTransparency))
        table.cell(maTable, column, 2,
          str.tostring(ma5_daily, format.mintick),
          bgcolor=color.new(ma5Color, tableTransparency))
        column += 1
    
    // MA6
    if ma6ShowTable
        table.cell(maTable, column, 1,
          'SMA(' + str.tostring(ma6Length) + ')',
          bgcolor=color.new(ma6Color, tableTransparency))
        table.cell(maTable, column, 2,
          str.tostring(ma6_daily, format.mintick),
          bgcolor=color.new(ma6Color, tableTransparency))
        column += 1
    
    // MA7
    if ma7ShowTable
        table.cell(maTable, column, 1,
          'SMA(' + str.tostring(ma7Length) + ')',
          bgcolor=color.new(ma7Color, tableTransparency))
        table.cell(maTable, column, 2,
          str.tostring(ma7_daily, format.mintick),
          bgcolor=color.new(ma7Color, tableTransparency))
        column += 1
    
    // MA8
    if ma8ShowTable
        table.cell(maTable, column, 1,
          'SMA(' + str.tostring(ma8Length) + ')',
          bgcolor=color.new(ma8Color, tableTransparency))
        table.cell(maTable, column, 2,
          str.tostring(ma8_daily, format.mintick),
          bgcolor=color.new(ma8Color, tableTransparency))
        column += 1
    
    // ATR
    if atrShowTable
        table.cell(maTable, column, 1,
          'ATR(' + str.tostring(atrPeriod) + ')',
          bgcolor=color.new(atrColor, tableTransparency))
        table.cell(maTable, column, 2,
          str.tostring(atr, format.mintick),
          bgcolor=color.new(atrColor, tableTransparency))

// Calculate SMAs (chart timeframe)
ma1 = ta.sma(close, ma1Length)
ma2 = ta.sma(close, ma2Length)
ma3 = ta.sma(close, ma3Length)
ma4 = ta.sma(close, ma4Length)
ma5 = ta.sma(close, ma5Length)
ma6 = ta.sma(close, ma6Length)
ma7 = ta.sma(close, ma7Length)
ma8 = ta.sma(close, ma8Length)

// Plot SMAs on chart
ma1Plot = plot(ma1Show ? ma1 : na, 'MA1', color=ma1Color)
ma2Plot = plot(ma2Show ? ma2 : na, 'MA2', color=ma2Color)
plot(ma3Show ? ma3 : na, 'MA3', color=ma3Color)
plot(ma4Show ? ma4 : na, 'MA4', color=ma4Color)
plot(ma5Show ? ma5 : na, 'MA5', color=ma5Color)
plot(ma6Show ? ma6 : na, 'MA6', color=ma6Color)
plot(ma7Show ? ma7 : na, 'MA7', color=ma7Color)
plot(ma8Show ? ma8 : na, 'MA8', color=ma8Color)

// Cloud shading between fast SMA and slow SMA
trendColor = if ma1Show and ma2Show
    ma1 > ma2 ? color.new(bullColor, trendTransparency) : color.new(bearColor, trendTransparency)
else
    na  // No cloud shading if either of fast or slow SMA is hidden

fill(ma1Plot, ma2Plot, color=trendColor)
